<Window x:Class="WindowsBlocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Windows Vault"
        Width="460" Height="720"
        MinWidth="380" MinHeight="520"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <!-- Dedicated, non-interactive rule host. User scripts execute only in
             its disposable workers, never in the editor's privileged page. -->
        <wv2:WebView2 x:Name="RuleWeb" Width="1" Height="1"
                      HorizontalAlignment="Left" VerticalAlignment="Top"
                      Opacity="0.01" IsHitTestVisible="False" Panel.ZIndex="0" />
        <wv2:WebView2 x:Name="Web" Panel.ZIndex="1" />
    </Grid>
</Window>
