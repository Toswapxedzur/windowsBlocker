<Window x:Class="WindowsBlocker.ToastOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        Focusable="False" IsHitTestVisible="False">
    <ItemsControl x:Name="Toasts" Width="380">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border CornerRadius="6" Margin="0,3,0,3" Background="{Binding Background}"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.35" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="{Binding Accent}"/>
                        <StackPanel Grid.Column="1" Margin="10,8,10,8">
                            <TextBlock Text="{Binding Meta}" FontSize="10" FontWeight="Medium"
                                       Foreground="{Binding MetaBrush}"/>
                            <TextBlock Text="{Binding Message}" FontSize="13" TextWrapping="Wrap"
                                       MaxHeight="80" Foreground="{Binding Foreground}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</Window>
